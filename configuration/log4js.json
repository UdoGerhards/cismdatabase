{
  "appenders": {
    "default": {
      "type": "stdout",
      "pattern": "-yyyy-MM-dd"
    },
    "defaultFile": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/cismdatabase.log"
    },
    "MongoDatabase": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/Database.log"
    },
    "QuestionDAO": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/QuestionDAO.log"
    },
    "AnswerDAO": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/AnswerDAO.log"
    },
    "TestDAO": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/TestDAO.log"
    },
    "TestAnswersDAO": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/TestAnswersDAO.log"
    },
    "UserDAO": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/UserDAO.log"
    },
    "LogManager": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/Server.log"
    },
    "Server": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/Server.log",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{HH:mm:ss}] [%p] %m"
      }
    },
    "MockExecutor": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/MockExecutor.log"
    },
    "MockQuestion": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/MockQuestion.log"
    },
    "MockTest": {
      "type": "file",
      "pattern": "-yyyy-MM-dd",
      "filename": "/var/log/cismserver/MockTest.log"
    }
  },
  "categories": {
    "MongoDatabase": {
      "appenders": [
        "MongoDatabase",
        "default"
      ],
      "level": "DEBUG",
      "enableCallStack": false
    },
    "QuestionDAO": {
      "appenders": [
        "QuestionDAO",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "AnswerDAO": {
      "appenders": [
        "AnswerDAO",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "TestDAO": {
      "appenders": [
        "TestDAO",
        "default"
      ],
      "level": "Info",
      "enableCallStack": false
    },
    "TestAnswersDAO": {
      "appenders": [
        "TestAnswersDAO",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "UserDAO": {
      "appenders": [
        "UserDAO",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "LogManager": {
      "appenders": [
        "LogManager",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "Server": {
      "appenders": [
        "Server",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "MockExecutor": {
      "appenders": [
        "MockExecutor",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "MockQuestion": {
      "appenders": [
        "MockQuestion",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "MockTest": {
      "appenders": [
        "MockTest",
        "default"
      ],
      "level": "INFO",
      "enableCallStack": false
    },
    "default": {
      "appenders": [
        "defaultFile"
      ],
      "level": "INFO",
      "enableCallStack": false
    }
  }
}
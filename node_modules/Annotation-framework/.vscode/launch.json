{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "command": "npm start",
            "name": "Run npm start",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run VSCode Extension Tests",
            "program": "${workspaceFolder}/test/runner/runTest.js",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "--nolazy"
            ],
            "args": [
                "-r",
                "bdd",
                "--timeout",
                "999999",
                "--colors",
                "${workspaceFolder}/test/**/*test.js",
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "command": "npm run test:unit",
            "name": "Unit tests",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "command": "npm run test:integration",
            "name": "Integration tests",
            "request": "launch",
            "type": "node-terminal",
        },
        {
            "command": "npm run test:functional",
            "name": "Functional tests",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "command": "npm run test:all",
            "name": "All tests",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Mocha Tests",
            "program": "${workspaceFolder}/node_modules/mocha/bin/_mocha",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "--nolazy"
            ],
            "args": [
                "--timeout",
                "999999",
                "--require",
                "${workspaceFolder}/test/runner/runTest.js",
                "--reporter",
                "dot",
                "--slow",
                "5000",
                "${workspaceFolder}/test/**/*.test.js",
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "openOnSessionStart",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Test Current File",
            "program": "${workspaceFolder}/node_modules/mocha/bin/mocha",
            "args": [
                "${file}",
                "--timeout",
                "5000"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}
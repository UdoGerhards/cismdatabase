{
  "name": "Annotation-framework",
  "version": "1.0.0",
  "description": "Modulares Annotation-basiertes Framework mit DI, Lifecycle und AST-Parsing",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "node ./test/runner/runTest.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:functional",
    "test:unit": "mocha \"test/unit/**/*.test.js\"",
    "test:integration": "mocha \"test/integration/**/*.test.js\"",
    "test:functional": "mocha \"test/functional/**/*.test.js\""
  },
  "framework": {
    "core": "src/core",
    "annotations": "src/annotations",
    "mock": "test/mocks"
  },
  "keywords": [
    "annotation",
    "dependency-injection",
    "lifecycle",
    "framework",
    "ast",
    "parser"
  ],
  "author": "Udo",
  "license": "MIT",
  "dependencies": {
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.2"
  },
  "devDependencies": {
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^5.3.3",
    "mocha": "^10.4.0",
    "sinon": "^17.0.1",
    "winston": "^3.11.0"
  }
}
